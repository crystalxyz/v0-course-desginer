# Course Designer environment variables.
#
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Settings → API). Without these, the app falls back to the
# "Continue as demo user" flow on /auth/login and stores courses in
# localStorage instead of Postgres.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
